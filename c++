六、主流程草图
这是你 main() 里建议跑的流程。

int main()
{
    // 1. 创建管理器
    LogManager logMgr;
    ConfigManager cfgMgr;
    DeviceManager devMgr;

    // 2. 加载配置
    cfgMgr.loadFromFile("config.txt");
    logMgr.addInfo("Config loaded");

    // 3. 初始化设备
    devMgr.addDevice(Device("01", "Bond_01"));
    devMgr.addDevice(Device("02", "Bond_02"));
    devMgr.addDevice(Device("03", "Bond_03"));
    logMgr.addInfo("Devices initialized");

    // 4. 显示初始设备
    devMgr.showAllDevices();

    // 5. 模拟收到状态报文
    MessageParser parser;
    std::string msg = "ID=01;TEMP=41.2;PRESS=1.10;ALARM=1";

    // 6. 解析并更新设备
    auto data = parser.parseMessage(msg);
    Device* dev = devMgr.findDeviceById(data["ID"]);
    if (dev != nullptr)
    {
        dev->setTemp(std::stod(data["TEMP"]));
        dev->setPressure(std::stod(data["PRESS"]));
        dev->checkAlarm(cfgMgr.getParam("TempLimit"), cfgMgr.getParam("PressureLimit"));
        logMgr.addWarn("Device 01 updated by message");
    }

    // 7. 通信命令测试
    CommManager comm(&logMgr, &devMgr);
    Command cmd("01", "START");
    comm.sendCommand(cmd);

    std::string resp = "ID=01;CMD=START;RESULT=OK";
    comm.processResponse(resp, cmd);

    // 8. 输出最终设备
    devMgr.showAllDevices();

    // 9. 保存日志
    logMgr.saveToFile("log.txt");

    return 0;
}
